#!/usr/bin/env bash
# Generated by Ansible (dotfiles role).
# ghq is the preferred checkout tool: clone every configured project, then
# register each ghq-managed repo with zoxide so `z <name>` works immediately.
{% for project in projects %}
ghq get {{ projects[project]['url'] }}
{% endfor %}

command ghq list --full-path | while IFS= read -r repo; do
  "{{ zoxide_exe }}" add "$repo"
done
