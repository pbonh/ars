#!/usr/bin/env bash
#
# hermes_wiki_ingest_batch
#
# Three-phase pipeline that turns a wiki's raw/ tree into a populated
# knowledge graph:
#
#   Phase 1 — pdf-to-mdbook (parallel, ingest-pipeline-batch skill)
#   Phase 2 — wiki-ingest + wiki-lint, sequential, ONE chapter at a time
#   Phase 3 — final wiki-lint sweep over the whole graph
#
# Phase 2 is deliberately serial. The wiki is a knowledge graph: each
# chapter creates/updates summary, concept, and entity pages plus their
# back-links. Running lint after every chapter catches contradictions and
# orphan links while they are cheap to fix; running it only at the end
# means the graph is messy by the time anyone notices. We also process
# books in deterministic slug order and chapters in the SUMMARY.md order
# emitted by the source mdBook, so a crash or interrupt resumes at the
# next chapter without redoing work.
#
# The chapter list comes from the wiki-ingest skill's triage script
# (--enumerate-chapters), so the source-of-truth for "what counts as a
# chapter" stays in one place.
#
# Why not pass --wiki-root to the batch skill? Because the skill enforces
# --parallel 1 when --wiki-root is set (wiki writes serialize on
# index.md / log.md / dashboard.md / analytics.md). For "parallel convert,
# then sequential ingest+lint" we want the parallel path the skill
# exposes when --wiki-root is omitted — and we drive ingest+lint here.
#
# Idempotency / resumability:
#   - Phase 1: the batch skill's library.json skips books with status:complete.
#   - Phase 2: <wiki>/wiki/.ingest-state.tsv records each completed
#     "<slug>\t<rel_path>" pair; previously-done chapters are skipped.
#   - Phase 3 (final lint) is idempotent.
#   - --force reprocesses everything (clears the state file too).
#
# Usage:
#   hermes_wiki_ingest_batch <wiki_root> [options]
#
# Options:
#   --parallel N        pdf-to-mdbook fan-out (phase 1 only). Default 2.
#   --vision MODE       vision mode passed to ingest-pipeline-batch. Default auto.
#   --force             reprocess everything (clears phase-2 state file too).
#   --lint-every N      run wiki-lint every N chapters. Default 1 (every chapter).
#   --skip-batch        skip phase 1 (pdf-to-mdbook).
#   --skip-ingest       skip phase 2 (per-chapter ingest+lint loop).
#   --skip-final-lint   skip phase 3 (whole-graph lint sweep).
#   -h | --help         this help.
#
# Examples:
#   # Default flow: parallel convert, then per-chapter ingest+lint, then final lint.
#   hermes_wiki_ingest_batch ~/wiki --parallel 3
#
#   # Already converted; just do ingest+lint over the wiki.
#   hermes_wiki_ingest_batch ~/wiki --skip-batch
#
#   # Lint every 5 chapters instead of every chapter (cheaper, looser graph).
#   hermes_wiki_ingest_batch ~/wiki --lint-every 5

set -Eeuo pipefail

usage() { sed -n '2,/^$/p' "$0" | sed 's/^# \?//' >&2; exit 2; }

[[ $# -ge 1 ]] || usage
case "$1" in -h|--help) usage ;; esac
WIKI="$(realpath "$1")"; shift
PARALLEL=2
VISION="auto"
FORCE=""
LINT_EVERY=1
SKIP_BATCH=""
SKIP_INGEST=""
SKIP_FINAL_LINT=""

while (($#)); do
  case "$1" in
    --parallel|-P)     PARALLEL="$2"; shift 2 ;;
    --vision)          VISION="$2";   shift 2 ;;
    --force)           FORCE="--force"; shift ;;
    --lint-every)      LINT_EVERY="$2"; shift 2 ;;
    --skip-batch)      SKIP_BATCH=1; shift ;;
    --skip-ingest)     SKIP_INGEST=1; shift ;;
    --skip-final-lint) SKIP_FINAL_LINT=1; shift ;;
    -h|--help)         usage ;;
    *) printf 'unknown arg: %s\n' "$1" >&2; usage ;;
  esac
done

LIBRARY="$WIKI/raw"
STATE="$WIKI/wiki/.ingest-state.tsv"
TRIAGE="$HOME/.hermes/skills/wiki-ingest/scripts/triage_source.py"

[[ -d "$WIKI"    ]] || { echo "wiki not found: $WIKI" >&2; exit 1; }
[[ -d "$LIBRARY" ]] || { echo "raw/ not found in wiki: $LIBRARY" >&2; exit 1; }
[[ -f "$TRIAGE"  ]] || { echo "wiki-ingest triage script missing: $TRIAGE" >&2; exit 1; }
command -v hermes  >/dev/null || { echo "hermes not on PATH"  >&2; exit 1; }
command -v python3 >/dev/null || { echo "python3 not on PATH" >&2; exit 1; }

[[ "$LINT_EVERY" =~ ^[0-9]+$ ]] && (( LINT_EVERY >= 1 )) || {
  echo "--lint-every must be a positive integer" >&2; exit 2; }

mkdir -p "$WIKI/wiki"
if [[ -n "$FORCE" && -f "$STATE" ]]; then : > "$STATE"; fi
[[ -f "$STATE" ]] || : > "$STATE"

RUN_ID="$(date -u +%Y%m%dT%H%M%SZ)-$$"
LOG_DIR="${HERMES_INGEST_LOG_DIR:-$HOME/.hermes/logs/wiki-ingest-batch}/$RUN_ID"
mkdir -p "$LOG_DIR"
SUMMARY="$LOG_DIR/summary.log"
say()  { printf '[%s] %s\n' "$(date -u +%H:%M:%SZ)" "$*" | tee -a "$SUMMARY" >&2; }

say "wiki=$WIKI library=$LIBRARY"
say "parallel=$PARALLEL vision=$VISION force=${FORCE:-no} lint-every=$LINT_EVERY"
say "state=$STATE log_dir=$LOG_DIR"

# ---------- Phase 1: pdf-to-mdbook ----------
if [[ -z "$SKIP_BATCH" ]]; then
  say "phase 1/3: ingest-pipeline-batch (parallel=$PARALLEL, no --wiki-root)"
  if hermes -s ingest-pipeline-batch -z "Sweep the library at $LIBRARY using ingest-pipeline-batch. Run with --parallel $PARALLEL --vision $VISION ${FORCE}. Do not pass --wiki-root — wiki ingestion happens in a separate phase. Stop after each book reaches mdbook build success. The only ingest-pipeline runner you may invoke is the deployed skill at ~/.hermes/skills/ingest-pipeline/scripts/run_pipeline.py — do NOT search the library tree or any workspace path for an ad-hoc run_pipeline.py / convert_pdf_to_mdbook.py / similar; those produce stub one-page-per-file output and a falsified pipeline.json. If the deployed skill is missing, stop and report it; do not improvise." \
      >"$LOG_DIR/batch.log" 2>&1; then
    say "batch ok ($LOG_DIR/batch.log)"
  else
    say "batch FAILED ($LOG_DIR/batch.log) — phase 2 will only see books that completed."
  fi
else
  say "phase 1/3: SKIPPED (--skip-batch)"
fi

# ---------- Phase 2: per-chapter ingest + lint, strictly sequential ----------
if [[ -z "$SKIP_INGEST" ]]; then
  say "phase 2/3: per-chapter ingest+lint (sequential, lint every $LINT_EVERY chapter[s])"

  CHAPTERS_JSONL="$LOG_DIR/chapters.jsonl"
  if ! python3 "$TRIAGE" "$WIKI" --enumerate-chapters >"$CHAPTERS_JSONL" 2>"$LOG_DIR/triage.err"; then
    say "triage FAILED — see $LOG_DIR/triage.err"; exit 1
  fi
  TOTAL=$(wc -l < "$CHAPTERS_JSONL" | tr -d ' ')
  say "triage emitted $TOTAL chapter group(s)"

  # Load existing state into an associative array for O(1) lookup. The state
  # file format is `<slug>\t<rel_path>` per line. Both the old per-section
  # runs and the new per-chapter runs emit the chapter's rel_path when its
  # group is processed, so resuming an in-flight per-section run "just
  # works" — chapter rel_paths that were already processed are skipped at
  # chapter granularity. Pass --force to start fresh.
  declare -A STATE_MAP
  if [[ -s "$STATE" ]]; then
    while IFS=$'\t' read -r _S _R; do
      [[ -n "$_S$_R" ]] && STATE_MAP["${_S}|${_R}"]=1
    done < "$STATE"
  fi

  CUR_BOOK=""
  IDX=0
  CHAPTERS_THIS_BOOK=0
  CHAPTERS_DONE=0
  CHAPTERS_SKIPPED=0
  LINT_COUNTER=0

  while IFS= read -r LINE; do
    [[ -z "$LINE" ]] && continue
    IDX=$((IDX + 1))

    # Parse one JSON record into shell vars: SLUG, KIND, REL, TITLE, IS_PART_N,
    # FILE_LIST_BLOCK (multi-line bullet list of all files in the group).
    # The Python below is wrapped in bash single quotes, so Python sees
    # double quotes as literal double quotes — use single quotes inside
    # f-string subscripts to avoid the escape-trap.
    eval "$(printf '%s' "$LINE" | python3 -c '
import json, shlex, sys, re
r = json.loads(sys.stdin.read())
title = r["title"]
m = re.search(r"\(part\s+(\d+)/(\d+)\)", title)
is_part_n = "1" if (m and int(m.group(1)) > 1) else "0"
files = []
if r["rel_path"] != "-":
    files.append("  - " + r["rel_path"] + " — " + title)
for p, t in zip(r["sub_paths"], r["sub_titles"]):
    files.append("  - " + p + " — " + t)
files_block = "\n".join(files)
print("SLUG=" + shlex.quote(r["slug"]))
print("KIND=" + shlex.quote(r["kind"]))
print("REL=" + shlex.quote(r["rel_path"]))
print("TITLE=" + shlex.quote(title))
print("IS_PART_N=" + is_part_n)
print("NUM_FILES=" + str(len(files)))
print("FILE_LIST_BLOCK=" + shlex.quote(files_block))
')"

    if [[ "$SLUG" != "$CUR_BOOK" ]]; then
      if [[ -n "$CUR_BOOK" ]]; then
        say "  └─ book complete: $CUR_BOOK ($CHAPTERS_THIS_BOOK chapter[s])"
      fi
      CUR_BOOK="$SLUG"
      CHAPTERS_THIS_BOOK=0
      say "▶ book: $SLUG (kind=$KIND)"
    fi
    CHAPTERS_THIS_BOOK=$((CHAPTERS_THIS_BOOK + 1))

    if [[ -n "${STATE_MAP[${SLUG}|${REL}]:-}" ]]; then
      CHAPTERS_SKIPPED=$((CHAPTERS_SKIPPED + 1))
      say "  · [$IDX/$TOTAL] skip (already in state): $REL"
      continue
    fi

    LABEL="$REL"
    [[ "$REL" == "-" ]] && LABEL="(whole source)"
    say "  · [$IDX/$TOTAL] ingest: $LABEL — $TITLE  (${NUM_FILES} file[s])"

    case "$KIND" in
      mdbook)
        if [[ "$IS_PART_N" == "1" ]]; then
          PART_DIRECTIVE="This is a continuation of an oversized chapter — extend the existing chapter section in wiki/summaries/$SLUG.md (the section was started by the prior \"part 1/N\" call). Do NOT create a new section header. Do NOT duplicate the chapter title in the log."
        else
          PART_DIRECTIVE="Add ONE new chapter section to wiki/summaries/$SLUG.md (creating the file if needed). Append ONE log entry for this chapter (not one per sub-file)."
        fi
        INGEST_PROMPT="Ingest exactly ONE CHAPTER GROUP from ONE book. Do not touch any other chapter or book in this turn.

Book slug: $SLUG
Chapter: $TITLE  ($REL)
Read ALL of these files in <mdbook_root>/src/ as a single chapter unit:
$FILE_LIST_BLOCK

$PART_DIRECTIVE

Create or update concept and entity pages for items introduced anywhere in the listed files. Update wiki/index.md.

After finishing, emit a final line beginning \"Files touched:\" listing every wiki/* path you modified, comma-separated, so the orchestrator can scope the lint pass. Do not parallelize. Do not start another chapter."
        ;;
      *)
        INGEST_PROMPT="Ingest exactly ONE source. Do not touch any other source in this turn.

Source slug: $SLUG
Source kind: $KIND (no mdBook available — fallback path)

Use the wiki-ingest workflow scoped to this single source. Run triage with --source pointing at raw/$SLUG, read the source per its kind, and produce the summary, concepts, entities, log entry, and index update for this source only.

After finishing, emit a final line beginning \"Files touched:\" listing every wiki/* path you modified, comma-separated, so the orchestrator can scope the lint pass. Do not parallelize. Do not start another source."
        ;;
    esac

    INGEST_LOG="$LOG_DIR/ingest-${IDX}.log"
    if ( cd "$WIKI" && hermes -s wiki-ingest -z "$INGEST_PROMPT" ) >"$INGEST_LOG" 2>&1; then
      printf '%s\t%s\n' "$SLUG" "$REL" >> "$STATE"
      STATE_MAP["${SLUG}|${REL}"]=1
      CHAPTERS_DONE=$((CHAPTERS_DONE + 1))
      LINT_COUNTER=$((LINT_COUNTER + 1))
      say "  · [$IDX/$TOTAL] ok ($INGEST_LOG)"
    else
      say "  ! [$IDX/$TOTAL] FAILED ($INGEST_LOG) — leaving in state as 'not done'; continuing"
      continue
    fi

    if (( LINT_COUNTER >= LINT_EVERY )); then
      LINT_COUNTER=0
      LINT_LOG="$LOG_DIR/lint-${IDX}.log"

      # Capture the agent's "Files touched:" line so lint can be scoped.
      # Match the LAST line that starts (after optional markdown bullet/quote
      # decoration) with "Files touched:". Fall back to whole-graph lint if absent.
      TOUCHED="$(grep -E '^[> *#-]*\s*Files touched:' "$INGEST_LOG" 2>/dev/null \
                 | tail -n 1 \
                 | sed -E 's/^[> *#-]*\s*Files touched:\s*//')"

      if [[ -n "$TOUCHED" ]]; then
        LINT_PROMPT="Scoped audit after chapter ingest ($SLUG :: $LABEL).

Scope this audit primarily to: $TOUCHED

Read those files first; run all standard checks (orphans, dead links, broken back-links, missing cross-links, contradictions) against them and any pages they directly link to. Update wiki/index.md and wiki/log.md statistics globally (cheap pass over filenames is fine). Skip the exhaustive whole-graph re-read step. Auto-fix what is safe; report the rest. The next chapter is queued."
      else
        LINT_PROMPT="Audit the wiki after the most recent chapter ingest ($SLUG :: $LABEL). Auto-fix safe issues (orphans, dead links, broken back-links, stale index counts, contradictions). Report the rest. Keep this scoped to a quick incremental sweep — the next chapter is queued."
      fi

      if ( cd "$WIKI" && hermes -s wiki-lint -z "$LINT_PROMPT" ) >"$LINT_LOG" 2>&1; then
        say "  · lint ok ($LINT_LOG)$([[ -n \"$TOUCHED\" ]] && echo ' [scoped]')"
      else
        say "  ! lint FAILED ($LINT_LOG) — continuing"
      fi
    fi
  done < "$CHAPTERS_JSONL"

  if [[ -n "$CUR_BOOK" ]]; then
    say "  └─ book complete: $CUR_BOOK ($CHAPTERS_THIS_BOOK chapter[s])"
  fi
  say "phase 2 done: $CHAPTERS_DONE ingested, $CHAPTERS_SKIPPED skipped (already in state), $((TOTAL - CHAPTERS_DONE - CHAPTERS_SKIPPED)) other"
else
  say "phase 2/3: SKIPPED (--skip-ingest)"
fi

# ---------- Phase 3: final lint sweep ----------
if [[ -z "$SKIP_FINAL_LINT" ]]; then
  say "phase 3/3: final wiki-lint sweep"
  if ( cd "$WIKI" && hermes -s wiki-lint -z "Final audit of this wiki: orphans, stale pages, dead links, contradictions, low-confidence pages, index/statistics drift. Auto-fix what is safe; report the rest." ) >"$LOG_DIR/wiki-lint-final.log" 2>&1; then
    say "final lint ok ($LOG_DIR/wiki-lint-final.log)"
  else
    say "final lint FAILED ($LOG_DIR/wiki-lint-final.log)"; exit 1
  fi
else
  say "phase 3/3: SKIPPED (--skip-final-lint)"
fi

say "complete. summary: $SUMMARY"
